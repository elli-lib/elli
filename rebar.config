{erl_first_files, ["src/elli_handler.erl"]}.
{erl_opts, [debug_info,
            {i, "include"},
            {platform_define, "^2", binary_http_uri},
            {platform_define, "^2[1-9]", post20}]}.
{minimum_otp_vsn, "20.0"}.
{deps, []}.
{xref_checks, [undefined_function_calls,locals_not_used]}.
{profiles, [
  {docs, [
    {deps,      [{edown, "0.8.1"}]},
    {edoc_opts, [
      {preprocess, true},
      {def, [
        {'EXAMPLE_CONF',"[{callback,elli_example_callback},{callback_args,[]}]"}
      ]},
      {doclet, edown_doclet}
    ]}
  ]},
  {test, [
    {deps,      [{hackney, "1.17.4"}]},
    {extra_src_dirs, [
        {"test", [
            {recursive, true}
        ]}
    ]},
    {cover_enabled, true},
    {cover_export_enabled, true},
    {cover_excl_mods, [
      elli_handler
    ]},
    {covertool, [{coverdata_files, ["ct.coverdata"]}]},
    {cover_opts, [verbose]},
    {ct_opts, [{ct_hooks, [cth_surefire]}]}
  ]}
]}.

{shell, [{script_file, "bin/shell.escript"}]}.

{project_plugins, [
  {covertool, "2.0.3"},
  {rebar3_lint, "v0.1.10"}
]}.

{dialyzer, [{plt_extra_apps, [ssl]}]}.

{post_hooks, [{edoc, "doc/build.sh"}]}.
