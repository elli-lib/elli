{erl_first_files, ["src/elli_handler.erl"]}.
{erl_opts, [debug_info,
            {i, "include"},
            {platform_define, "^2", binary_http_uri},
            {platform_define, "^2[1-9]", post20}]}.
{minimum_otp_vsn, "20.0"}.
{deps, []}.
{xref_checks, [undefined_function_calls,locals_not_used]}.
{profiles, [
  {test, [
    {deps,      [{hackney, "1.17.4"}]}
  ]}
]}.

{shell, [{script_file, "bin/shell.escript"}]}.

{project_plugins, [
  {covertool, "2.0.3"},
  {rebar3_lint, "v0.1.10"},
  {rebar3_ex_doc, "0.2.18"}
]}.
{ex_doc, [
    {extras, [
        "CHANGELOG.md",
        "LICENSE",
        "README.md"
    ]},
    {main, "README.md"},
    {source_url, "https://github.com/elli-lib/elli"}
]}.
{hex, [
    {doc, #{provider => ex_doc}}
]}.

{provider_hooks, [{pre, [{eunit, lint}]}]}.
{dialyzer, [{plt_extra_apps, [ssl]}]}.

{cover_enabled, true}.
{cover_export_enabled, true}.
{cover_excl_mods, [
  elli_handler
]}.
{covertool, [{coverdata_files, ["eunit.coverdata"]}]}.

{ct_opts, [{ct_hooks, [cth_surefire]}]}.
